# OpenAI configuration
OPENAI_API_KEY=your-openai-api-key-here

# Optional: override the default chat model (defaults to gpt-5)
OPENAI_MODEL=gpt-5

# Optional: point at an OpenAI-compatible endpoint (leave unset for the official API)
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
